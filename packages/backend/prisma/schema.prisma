  expectedWeightTons Decimal? @map("expected_weight_tons") @db.Decimal(10, 3)
  expectedAmount Decimal? @map("expected_amount") @db.Decimal(14, 2)

  @@map("purchase_order_line")
}

model GoodsReceipt {
