  sourceFile   String?   @map("source_file")
  importDate   DateTime  @default(now()) @map("import_date")
  periodStart  DateTime? @map("period_start") @db.Date
  periodEnd    DateTime? @map("period_end") @db.Date

  ledgerEntries      TallyLedgerEntry[]
  trialBalanceRows   TallyTrialBalanceSnapshot[]

  @@map("tally_import_batch")
}

model TallyLedgerEntry {
  id                    String            @id @default(uuid())
  tallyImportBatchId    String            @map("tally_import_batch_id")
  batch                 TallyImportBatch  @relation(fields: [tallyImportBatchId], references: [id])
  voucherType           String?           @map("voucher_type")
  entryDate             DateTime?         @map("entry_date") @db.Date
  account               String?
  debit                 Decimal?          @db.Decimal(14, 2)
  credit                Decimal?          @db.Decimal(14, 2)
  narration             String?

  @@map("tally_ledger_entry")
}

model TallyTrialBalanceSnapshot {
  id                   String            @id @default(uuid())
  tallyImportBatchId   String            @map("tally_import_batch_id")
  batch                TallyImportBatch  @relation(fields: [tallyImportBatchId], references: [id])
  account              String?
  debit                Decimal?          @db.Decimal(14, 2)
  credit               Decimal?          @db.Decimal(14, 2)

  @@map("tally_trial_balance_snapshot")
}

model InventorySnapshot {
  id                        String   @id @default(uuid())
  factoryId                 String   @map("factory_id")
  factory                   Factory  @relation(fields: [factoryId], references: [id])
  snapshotDate              DateTime @map("snapshot_date") @db.Date
  itemType                  String   @map("item_type") // raw_block / slab / consumable
  quantityOnHand            Decimal? @map("quantity_on_hand") @db.Decimal(12, 2)
  valueOnHand               Decimal? @map("value_on_hand") @db.Decimal(14, 2)
  daysSinceLastMovement     Int?     @map("days_since_last_movement")
  createdAt                 DateTime @default(now()) @map("created_at")

  @@unique([factoryId, snapshotDate, itemType])
