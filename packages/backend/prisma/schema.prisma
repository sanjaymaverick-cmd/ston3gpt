}

model UtilityReading {
  id                         String   @id @default(uuid())
  factoryId                  String   @map("factory_id")
  factory                    Factory  @relation(fields: [factoryId], references: [id])
  readingDate                DateTime @map("reading_date") @db.Date
  solarGenerationKwh         Decimal? @map("solar_generation_kwh") @db.Decimal(10, 2)
  gridExportKwh              Decimal? @map("grid_export_kwh") @db.Decimal(10, 2)
  gridImportKwh              Decimal? @map("grid_import_kwh") @db.Decimal(10, 2)
  machineConsumptionKwh      Decimal? @map("machine_consumption_kwh") @db.Decimal(10, 2)
