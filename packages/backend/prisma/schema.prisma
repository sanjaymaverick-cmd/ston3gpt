  createdAt                  DateTime @default(now()) @map("created_at")

  @@map("utility_reading")
}

model OpeningInventorySnapshot {
  id          String @id @default(uuid())
  factoryId   String @map("factory_id")
  factory     Factory @relation(fields: [factoryId], references: [id])
  countDate   DateTime @map("count_date") @db.Date
  status      OpeningSnapshotStatus @default(DRAFT)
  createdBy   String @map("created_by")
  submittedBy String? @map("submitted_by")
  submittedAt DateTime? @map("submitted_at")
  approvedBy  String? @map("approved_by")
  approvedAt  DateTime? @map("approved_at")
  rejectedBy  String? @map("rejected_by")
  rejectedAt  DateTime? @map("rejected_at")
  rejectionReason String? @map("rejection_reason")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lines OpeningInventoryLine[]

  @@map("opening_inventory_snapshot")
}

model OpeningInventoryLine {
  id          String @id @default(uuid())
  snapshotId  String @map("snapshot_id")
  snapshot    OpeningInventorySnapshot @relation(fields: [snapshotId], references: [id])
  inventoryKind InventoryKind @map("inventory_kind")
  rawBlockId  String? @map("raw_block_id")
  rawBlock    RawBlock? @relation("OpeningLineRawBlock")
  slabId      String? @map("slab_id")
  slab        Slab? @relation("OpeningLineSlab")
  count       Int @default(1)
  areaSqft    Decimal? @map("area_sqft") @db.Decimal(12, 2)
  openingValue Decimal? @map("opening_value") @db.Decimal(14, 2)
  locationId  String @map("location_id")
  location    InventoryLocation @relation(fields: [locationId], references: [id])
  ownershipType OwnershipType @map("ownership_type")
  verificationStatus VerificationStatus @map("verification_status")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  movements InventoryMovement[]

  @@map("opening_inventory_line")
}

model InventoryMovement {
  id          String @id @default(uuid())
  factoryId   String @map("factory_id")
  factory     Factory @relation(fields: [factoryId], references: [id])
  movementType InventoryMovementType @map("movement_type")
  occurredAt  DateTime @default(now()) @map("occurred_at")
  rawBlockId  String? @map("raw_block_id")
  rawBlock    RawBlock? @relation(fields: [rawBlockId], references: [id])
  slabId      String? @map("slab_id")
  slab        Slab? @relation(fields: [slabId], references: [id])
  fromLocationId String? @map("from_location_id")
  fromLocation InventoryLocation? @relation("MovementFromLocation", fields: [fromLocationId], references: [id])
  toLocationId String? @map("to_location_id")
  toLocation InventoryLocation? @relation("MovementToLocation", fields: [toLocationId], references: [id])
  quantity    Decimal @default(1) @db.Decimal(12, 3)
  areaSqft    Decimal? @map("area_sqft") @db.Decimal(12, 2)
  referenceType String @map("reference_type")
  referenceId String @map("reference_id")
  reversesMovementId String? @map("reverses_movement_id")
  reversesMovement InventoryMovement? @relation("InventoryMovementReversal", fields: [reversesMovementId], references: [id])
  reversedBy InventoryMovement[] @relation("InventoryMovementReversal")
  createdBy String @map("created_by")
  reason String?
  idempotencyKey String @map("idempotency_key")
  cuttingSessionId String? @map("cutting_session_id")
  cuttingSession CuttingSession? @relation(fields: [cuttingSessionId], references: [id])
  polishingSessionId String? @map("polishing_session_id")
  polishingSession PolishingSession? @relation(fields: [polishingSessionId], references: [id])
  openingInventoryLineId String? @map("opening_inventory_line_id")
  openingInventoryLine OpeningInventoryLine? @relation(fields: [openingInventoryLineId], references: [id])
  goodsReceiptLineId String? @map("goods_receipt_line_id")
  goodsReceiptLine GoodsReceiptLine? @relation(fields: [goodsReceiptLineId], references: [id])
  deliveryLineId String? @map("delivery_line_id")
  deliveryLine DeliveryLine? @relation(fields: [deliveryLineId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([factoryId, idempotencyKey])
  @@index([factoryId, rawBlockId])
  @@index([factoryId, slabId])
  @@map("inventory_movement")
}

model InventoryReservation {
  id          String @id @default(uuid())
  factoryId   String @map("factory_id")
  factory     Factory @relation(fields: [factoryId], references: [id])
  rawBlockId  String? @map("raw_block_id")
  rawBlock    RawBlock? @relation(fields: [rawBlockId], references: [id])
  slabId      String? @map("slab_id")
  slab        Slab? @relation(fields: [slabId], references: [id])
  purpose     ReservationPurpose
  status      ReservationStatus @default(ACTIVE)
  referenceType String @map("reference_type")
  referenceId String @map("reference_id")
  createdBy String @map("created_by")
  releasedBy String? @map("released_by")
  consumedBy String? @map("consumed_by")
  createdAt DateTime @default(now()) @map("created_at")
  releasedAt DateTime? @map("released_at")
  consumedAt DateTime? @map("consumed_at")
  cuttingSession CuttingSession[] @relation("CuttingSessionReservation")
  polishingSessionId String? @map("polishing_session_id")
  polishingSession PolishingSession? @relation(fields: [polishingSessionId], references: [id])
  salesReservation SalesReservation?

  @@index([factoryId, rawBlockId, status])
  @@index([factoryId, slabId, status])
  @@map("inventory_reservation")
}

model SalesReservation {
  id          String @id @default(uuid())
  factoryId   String @map("factory_id")
  salesOrderId String @map("sales_order_id")
  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id])
  salesLineItemId String @unique @map("sales_line_item_id")
  salesLineItem SalesLineItem @relation(fields: [salesLineItemId], references: [id])
  slabId String @map("slab_id")
  reservationId String @unique @map("reservation_id")
  reservation InventoryReservation @relation(fields: [reservationId], references: [id])
  status ReservationStatus @default(ACTIVE)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([factoryId, slabId, status])
  @@map("sales_reservation")
}

model Delivery {
  id          String @id @default(uuid())
  factoryId   String @map("factory_id")
  factory     Factory @relation(fields: [factoryId], references: [id])
  salesOrderId String @map("sales_order_id")
  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id])
  deliveryDate DateTime @map("delivery_date") @db.Date
  vehicleNumber String? @map("vehicle_number")
  createdBy String @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  lines DeliveryLine[]

  @@map("delivery")
}

model DeliveryLine {
  id          String @id @default(uuid())
  deliveryId String @map("delivery_id")
  delivery Delivery @relation(fields: [deliveryId], references: [id])
  slabId String @map("slab_id")
